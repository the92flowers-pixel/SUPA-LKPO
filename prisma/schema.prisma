generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int       @id @default(autoincrement())
  login        String    @unique
  password     String    // bcrypt hash
  role         String    // "admin" або "artist"
  artistName   String?
  profileFields Json?     // збереження значень динамічних полів профілю
  tracks       Track[]
  createdAt    DateTime  @default(now())
}

model Track {
  id           Int       @id @default(autoincrement())
  externalId   String    @unique
  artistId     Int
  artist       User      @relation(fields: [artistId], references: [id])
  customFields Json?      // значення динамічних полів релізу
  status       String    // відповідає Status.name
  streams      Stream[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Stream {
  id        Int      @id @default(autoincrement())
  trackId   Int
  track     Track    @relation(fields: [trackId], references: [id])
  date      DateTime
  count     Int
}

model CustomField {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  label     String
  type      String   // "text", "select", "date", "url", "number", "textarea"
  options   String?  // JSON масив для select
  required  Boolean  @default(false)
  order     Int
  visible   Boolean  @default(true)
  forRole   String   // "artist", "admin"
  section   String   // "release" або "profile"
}

model Status {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  color     String   // "yellow", "green", "red", "blue", "gray"
  order     Int
  isDefault Boolean  @default(false)
  visible   Boolean  @default(true)
}

model AdminSetting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String // JSON
}

model LoginPageContent {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}